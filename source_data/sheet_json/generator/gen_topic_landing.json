{
  "flow_type": "generator",
  "flow_name": "gen_topic_landing",
  "status": "released",
  "parameter_list": {
    "input_data_list": "topic_released",
    "output_flow_name": "topic_landing_@gen.id",
    "output_flow_type": "template"
  },
  "rows": [
    {
      "type": "begin_data_items",
      "name": "check_topic_completion",
      "value": "topic_tasks",
      "parameter_list": "filter: @item.id == \"@gen.id\""
    },
    {
      "name": "postcompose",
      "value": "_start_at_uncompleted_with_congrats"
    },
    {
      "type": "begin_template",
      "name": "topic_landing",
      "value": "topic_landing",
      "action_list": "completed | emit: completed; \nuncompleted | emit: uncompleted"
    },
    {
      "name": "topic_id",
      "value": "@gen.id"
    },
    {
      "name": "use_pop_up",
      "value": true,
      "condition": "!@item.completed"
    },
    {
      "name": "topic_target_template",
      "value": "topic_@gen.id@local.postcompose",
      "condition": "!@item.completed"
    },
    {
      "type": "end_template"
    },
    {
      "type": "end_data_items"
    }
  ]
}