{
  "flow_type": "template",
  "flow_name": "overall_activities",
  "status": "released",
  "rows": [
    {
      "name": "activity",
      "value": "Farm Activities"
    },
    {
      "name": "fav_page",
      "value": "fav_farm_activities",
      "exclude_from_translation": true
    },
    {
      "type": "title",
      "name": "title",
      "value": "@local.activity",
      "exclude_from_translation": true
    },
    {
      "name": "favourite",
      "value": "My Favourites"
    },
    {
      "name": "favourite_image_asset",
      "value": "images/icons/fine_heart.svg",
      "exclude_from_translation": true
    },
    {
      "name": "favourite_checked_image_asset",
      "value": "images/icons/full_heart.svg",
      "exclude_from_translation": true
    },
    {
      "type": "task_card",
      "name": "task_card",
      "value": "@local.favourite",
      "action_list": "click |  go_to: @local.fav_page",
      "parameter_list": "title: @local.favourite;\nimage: @local.favourite_image_asset;\nvariant: button;",
      "exclude_from_translation": true
    },
    {
      "name": "tags",
      "value": "activities_tags",
      "exclude_from_translation": true
    },
    {
      "name": "all",
      "value": "All"
    },
    {
      "type": "combo_box",
      "name": "select_tag",
      "parameter_list": "variant: dropdown;\nanswer_list: @data.@local.tags; \nplaceholder: @local.all;",
      "exclude_from_translation": true
    },
    {
      "name": "data_list",
      "value": "activities",
      "exclude_from_translation": true
    },
    {
      "type": "begin_display_grid",
      "name": "display_grid",
      "value": "dg_1",
      "parameter_list": "item_width: 150px; item_border: none",
      "exclude_from_translation": true
    },
    {
      "type": "begin_data_items",
      "name": "loop_activities",
      "value": "@local.data_list",
      "exclude_from_translation": true
    },
    {
      "name": "data_list_in_loop",
      "value": "activities",
      "exclude_from_translation": true
    },
    {
      "name": "go_to_template_prefix",
      "value": "article_",
      "exclude_from_translation": true
    },
    {
      "name": "activity_id",
      "value": "@item.id",
      "exclude_from_translation": true
    },
    {
      "name": "activity_concat",
      "value": "@local.data_list.@local.activity_id",
      "exclude_from_translation": true
    },
    {
      "name": "activity_data",
      "value": "@data.@local.activity_concat",
      "exclude_from_translation": true
    },
    {
      "name": "activity_tag_list",
      "value": "@item.tag_list",
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "debug_@item.id",
      "value": "tags array: @local.activity_tag_list\nselected tag: @local.select_tag",
      "condition": false,
      "exclude_from_translation": true
    },
    {
      "name": "has_selected_tag",
      "value": "@calc(Array.isArray(@local.activity_tag_list) ? @local.activity_tag_list.includes(@local.select_tag) : @local.activity_tag_list == @local.select_tag)",
      "condition": false,
      "exclude_from_translation": true,
      "comment": "@calc() block (or JS expression in a set_variable row) inside a data-items loop does not have access to local variables defined outside of the data-items loop. "
    },
    {
      "type": "text",
      "name": "debug_2_@item.id",
      "value": "has selected tag: @local.has_selected_tag",
      "condition": false,
      "exclude_from_translation": true
    },
    {
      "name": "go_to_template",
      "value": "@local.go_to_template_prefix@local.activity_id",
      "exclude_from_translation": true
    },
    {
      "name": "join",
      "value": "_",
      "exclude_from_translation": true
    },
    {
      "name": "now",
      "value": "@calc(timestamp())",
      "exclude_from_translation": true
    },
    {
      "name": "click_history",
      "value": "_click_history",
      "exclude_from_translation": true
    },
    {
      "name": "click_history_field_name",
      "value": "@local.data_list_in_loop@local.join@item.id@local.click_history",
      "exclude_from_translation": true
    },
    {
      "name": "click_history_value",
      "value": "@fields.@local.click_history_field_name ;  @local.now",
      "condition": "!!(@fields.@local.click_history_field_name)",
      "exclude_from_translation": true
    },
    {
      "name": "click_history_value",
      "value": "@local.now",
      "condition": "!(@fields.@local.click_history_field_name)",
      "exclude_from_translation": true
    },
    {
      "type": "begin_button",
      "name": "card_@item.id",
      "value": "@item.title",
      "action_list": "click | set_field: @local.click_history_field_name: @local.click_history_value;\nclick | go_to: @local.go_to_template;",
      "parameter_list": "variant: card-portrait;\nimage_asset: @item.image_cover_asset;",
      "condition": "!@local.select_tag || @local.activity_tag_list.includes(@local.select_tag)",
      "exclude_from_translation": true
    },
    {
      "type": "toggle_bar",
      "name": "toggle_@item.id",
      "value": "@item.favourite",
      "action_list": "changed | set_item | favourite: !@item.favourite",
      "parameter_list": "variant: icon; \nicon_true_asset: @local.favourite_checked_image_asset;\nicon_false_asset: @local.favourite_image_asset;",
      "exclude_from_translation": true
    },
    {
      "type": "end_button",
      "exclude_from_translation": true
    },
    {
      "type": "end_data_items",
      "exclude_from_translation": true
    },
    {
      "type": "end_display_grid",
      "exclude_from_translation": true
    }
  ]
}